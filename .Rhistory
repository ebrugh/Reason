f_efunc <- function(x)
if (!is.numeric(x)) return(error){
f_efunc <- function(x)
if (!is.numeric(x)) return(error) {
f.efunc <- function(x)
if (!is.numeric(x)) return(error) {
f.efunc <- function(x)
if (!is.numeric(x)) stop(Error) {
f.efunc <- function(x){
if (!is.numeric(x)) stop("Error")
mean = mean(x)
median = median(x)
maximum = maximum(x)
minimum = minimum(x)
sort(x)}
f.efunc(c(1, 0, -1))
f.efunc(c(1,0,-1))
f.efunc <- function(x){
if (!is.numeric(x)) stop("Error")
mean = mean(x)
median = median(x)
max = max(x)
min = min(x)
sort(x)}
f.efunc(c(1,0,-1))
f.efunc(c(10,1000,100))
f.efunc(c(.1, .001, 1e8))
f.efunc(c("a", "b", "c"))
