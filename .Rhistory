d.counties %>% {}
as_tibble() %>% select(-geometry) %>%
group_by(STATEFP10) %>%
mutate(state_total_area = sum(ALAND10 + AWATER10),
land_pct_of_state_total = (ALAND10 / state_total_area) * 100) %>%
ungroup()
d.counties %>% {
as_tibble(d.counties) %>% dplyr::select(-geometry) %>%
group_by(STATEFP10) %>%
summarise(stateWaterArea = sum(ALAND10))}
d.counties %>% {
as_tibble(d.counties) %>% dplyr::select(-geometry) %>%
group_by(STATEFP10) %>%
summarise(stateWaterArea = sum(AWATER10))}
d.counties %>% {
as_tibble(d.counties) %>% select(-geometry) %>%
group_by(STATEFP10) %>%
mutate(st_total = sum(ALAND10 + AWATER10))}
d.counties %>% {
as_tibble(d.counties) %>% dplyr::select(-geometry) %>%
group_by(STATEFP10) %>%
